@page "/admin/users/edit/{UserId}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using GMMW.Web.Models.ViewModels
@using GMMW.Web.Services.Interfaces
@attribute [Authorize(Roles = "SuperUser")]
@inject IUserAdminService UserAdminService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(string.IsNullOrWhiteSpace(FormModel.UserId) ? "Edit User" : $"Edit {FormModel.FirstName} {FormModel.LastName}")</PageTitle>

<div class="row">
    <div class="col-12 col-xl-10 col-xxl-8">
        <div class="st-stack-lg">
            <div class="st-page-header">
                <div class="st-page-header__copy">
                    <h1 class="st-page-title">
                        @(string.IsNullOrWhiteSpace(FormModel.UserId) ? "Edit User" : $"Edit {FormModel.FirstName} {FormModel.LastName}")
                    </h1>
                    <p class="st-page-subtitle">
                        Update the selected internal user account details while keeping access control managed through Identity roles.
                    </p>
                </div>

                <div class="st-page-actions">
                    <a href="/admin" class="st-btn st-btn--secondary">Back to Users</a>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="st-card">
                    <div class="st-card__body">
                        <div class="st-alert st-alert--info mb-0" role="status">
                            Loading user details...
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(notFoundMessage))
            {
                <div class="st-card">
                    <div class="st-card__body">
                        <div class="st-alert st-alert--warning mb-0" role="alert">
                            @notFoundMessage
                        </div>
                    </div>
                </div>
            }
            else
            {
                <EditForm Model="FormModel"
                          OnValidSubmit="HandleValidSubmit"
                          OnInvalidSubmit="HandleInvalidSubmit"
                          FormName="UserEdit">
                    <DataAnnotationsValidator />

                    <div class="st-card st-card--allow-overflow">
                        <div class="st-card__header">
                            <div>
                                <h2 class="st-card-title">User Details</h2>
                                <p class="st-card-subtitle">
                                    Review and update the selected internal user account.
                                </p>
                            </div>
                        </div>

                        <div class="st-card__body">
                            @if (!string.IsNullOrWhiteSpace(errorMessage))
                            {
                                <div class="st-alert st-alert--danger mb-3" role="alert" aria-live="polite">
                                    @errorMessage
                                </div>
                            }

                            @if (showValidationMessage && string.IsNullOrWhiteSpace(errorMessage))
                            {
                                <div class="st-alert st-alert--warning mb-3" role="alert">
                                    Please correct the highlighted fields and try again.
                                </div>
                            }

                            <fieldset disabled="@isSaving" aria-busy="@isSaving">
                                <div class="row g-4">
                                    <div class="col-12 col-md-6">
                                        <div class="st-field mb-0">
                                            <label for="first-name" class="st-label">First Name</label>
                                            <InputText id="first-name"
                                                       class="st-input"
                                                       autocomplete="given-name"
                                                       @bind-Value="FormModel.FirstName" />
                                            <ValidationMessage For="() => FormModel.FirstName" class="validation-message" />
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <div class="st-field mb-0">
                                            <label for="last-name" class="st-label">Last Name</label>
                                            <InputText id="last-name"
                                                       class="st-input"
                                                       autocomplete="family-name"
                                                       @bind-Value="FormModel.LastName" />
                                            <ValidationMessage For="() => FormModel.LastName" class="validation-message" />
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="st-field mb-0">
                                            <label for="email" class="st-label">Email</label>
                                            <InputText id="email"
                                                       type="email"
                                                       class="st-input"
                                                       autocomplete="email"
                                                       inputmode="email"
                                                       @bind-Value="FormModel.Email" />
                                            <ValidationMessage For="() => FormModel.Email" class="validation-message" />
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="st-field mb-0">
                                            <label for="account-status-trigger" class="st-label">Account Status</label>

                                            <div class="st-dropdown">
                                                <button id="account-status-trigger"
                                                        type="button"
                                                        class="st-select st-dropdown__trigger"
                                                        @onclick="ToggleAccountStatusDropdown"
                                                        aria-expanded="@isAccountStatusDropdownOpen"
                                                        aria-haspopup="listbox">
                                                    <span>@SelectedAccountStatusText</span>
                                                    <span class="st-dropdown__chevron">▾</span>
                                                </button>

                                                @if (isAccountStatusDropdownOpen)
                                                {
                                                    <button type="button"
                                                            class="st-dropdown__backdrop"
                                                            @onclick="CloseAccountStatusDropdown"
                                                            aria-label="Close account status menu"></button>

                                                    <div class="st-dropdown__menu"
                                                         role="listbox"
                                                         aria-labelledby="account-status-trigger">
                                                        <button type="button"
                                                                class="st-dropdown__item"
                                                                @onclick="() => SelectAccountStatus(true)">
                                                            Active
                                                        </button>

                                                        <button type="button"
                                                                class="st-dropdown__item"
                                                                @onclick="() => SelectAccountStatus(false)">
                                                            Disabled
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </fieldset>

                            <div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-2 mt-4 pt-4 border-top">
                                <button type="submit" class="st-btn st-btn--primary" disabled="@isSaving">
                                    @(isSaving ? "Saving Changes..." : "Save Changes")
                                </button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    // Gets the selected user ID from the route.
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    // Stores the posted form values for the edit-user page.
    [SupplyParameterFromForm(FormName = "UserEdit")]
    private UserEditViewModel? model { get; set; }

    // Always provides a safe non-null model instance for rendering and form binding.
    private UserEditViewModel FormModel => model ??= new();

    // Stores service or unexpected errors shown above the form.
    private string? errorMessage;

    // Stores the not-found message if the requested user does not exist.
    private string? notFoundMessage;

    // Controls the loading state while the user data is being fetched.
    private bool isLoading = true;

    // Prevents duplicate submits while saving.
    private bool isSaving;

    // Shows one short validation prompt after an invalid submit.
    private bool showValidationMessage;

    // Controls the custom account-status dropdown state.
    private bool isAccountStatusDropdownOpen;

    // Shows the currently selected account status in the dropdown trigger.
    private string SelectedAccountStatusText => FormModel.IsActive ? "Active" : "Disabled";

    // Reloads the selected user whenever the route parameter changes.
    protected override async Task OnParametersSetAsync()
    {
        await LoadUserAsync();
    }

    // Loads the current user details into the edit model.
    private async Task LoadUserAsync()
    {
        errorMessage = null;
        notFoundMessage = null;
        showValidationMessage = false;
        isLoading = true;
        isAccountStatusDropdownOpen = false;

        model = new UserEditViewModel();

        try
        {
            var loadedUser = await UserAdminService.GetUserByIdAsync(UserId);

            if (loadedUser is null)
            {
                notFoundMessage = "The requested user could not be found.";
                return;
            }

            FormModel.UserId = loadedUser.UserId;
            FormModel.FirstName = loadedUser.FirstName;
            FormModel.LastName = loadedUser.LastName;
            FormModel.Email = loadedUser.Email;
            FormModel.IsActive = loadedUser.IsActive;
        }
        catch
        {
            errorMessage = "Something went wrong while loading the user.";
        }
        finally
        {
            isLoading = false;
        }
    }

    // Opens or closes the account-status dropdown.
    private void ToggleAccountStatusDropdown()
    {
        isAccountStatusDropdownOpen = !isAccountStatusDropdownOpen;
    }

    // Applies the selected account status and closes the dropdown.
    private void SelectAccountStatus(bool isActive)
    {
        FormModel.IsActive = isActive;
        isAccountStatusDropdownOpen = false;
    }

    // Closes the dropdown when the backdrop is clicked.
    private void CloseAccountStatusDropdown()
    {
        isAccountStatusDropdownOpen = false;
    }

    // Saves the updated user details.
    private async Task HandleValidSubmit()
    {
        if (isSaving)
        {
            return;
        }

        errorMessage = null;
        showValidationMessage = false;
        isAccountStatusDropdownOpen = false;
        isSaving = true;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(currentUserId))
            {
                errorMessage = "The current signed-in user could not be identified.";
                return;
            }

            await UserAdminService.UpdateUserAsync(FormModel, currentUserId);

            NavigationManager.NavigateTo("/admin");
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "Something went wrong while updating the user.";
        }
        finally
        {
            isSaving = false;
        }
    }

    // Runs when submit happens but validation fails.
    private void HandleInvalidSubmit(EditContext editContext)
    {
        errorMessage = null;
        showValidationMessage = true;
        isAccountStatusDropdownOpen = false;
    }
}
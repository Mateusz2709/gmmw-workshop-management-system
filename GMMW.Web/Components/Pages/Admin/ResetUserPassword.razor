@page "/admin/users/reset-password/{UserId}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using GMMW.Web.Models.ViewModels
@using GMMW.Web.Services.Interfaces
@attribute [Authorize(Roles = "SuperUser")]
@inject IUserAdminService UserAdminService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(string.IsNullOrWhiteSpace(targetDisplayName) ? "Reset User Password" : $"Reset {targetDisplayName} Password")</PageTitle>

<div class="row">
    <div class="col-12 col-xl-8 col-xxl-7">
        <div class="st-stack-lg">
            <div class="st-page-header">
                <div class="st-page-header__copy">
                    <h1 class="st-page-title">
                        @(string.IsNullOrWhiteSpace(targetDisplayName) ? "Reset User Password" : $"Reset {targetDisplayName} Password")
                    </h1>
                    <p class="st-page-subtitle">
                        Set a new password for the selected internal user account from the protected admin area.
                    </p>
                </div>

                <div class="st-page-actions">
                    <a href="/admin" class="st-btn st-btn--secondary">Back to Users</a>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="st-card">
                    <div class="st-card__body">
                        <div class="st-alert st-alert--info mb-0" role="status">
                            Loading user details...
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(notFoundMessage))
            {
                <div class="st-card">
                    <div class="st-card__body">
                        <div class="st-alert st-alert--warning mb-0" role="alert">
                            @notFoundMessage
                        </div>
                    </div>
                </div>
            }
            else
            {
                <EditForm Model="FormModel"
                          OnValidSubmit="HandleValidSubmit"
                          OnInvalidSubmit="HandleInvalidSubmit"
                          FormName="ResetUserPassword">
                    <DataAnnotationsValidator />

                    <div class="st-card">
                        <div class="st-card__header">
                            <div>
                                <h2 class="st-card-title">Password Reset Details</h2>
                                <p class="st-card-subtitle">
                                    Enter and confirm a new password for the selected internal user.
                                </p>
                            </div>
                        </div>

                        <div class="st-card__body">
                            @if (!string.IsNullOrWhiteSpace(errorMessage))
                            {
                                <div class="st-alert st-alert--danger mb-3" role="alert" aria-live="polite">
                                    @errorMessage
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(successMessage))
                            {
                                <div class="st-alert st-alert--success mb-3" role="status" aria-live="polite">
                                    @successMessage
                                </div>
                            }

                            @if (showValidationMessage &&
                                                             string.IsNullOrWhiteSpace(errorMessage) &&
                                                             string.IsNullOrWhiteSpace(successMessage))
                            {
                                <div class="st-alert st-alert--warning mb-3" role="alert">
                                    Please correct the highlighted fields and try again.
                                </div>
                            }

                            <div class="st-alert st-alert--info mb-3" role="status">
                                Resetting password for
                                <strong>@targetDisplayName</strong>
                                @if (!string.IsNullOrWhiteSpace(targetEmail))
                                {
                                    <span> (@targetEmail)</span>
                                }
                                .
                            </div>

                            <fieldset disabled="@isSaving" aria-busy="@isSaving">
                                <div class="row g-4">
                                    <div class="col-12 col-md-6">
                                        <div class="st-field mb-0">
                                            <label for="new-password" class="st-label">New Password</label>
                                            <InputText id="new-password"
                                                       type="password"
                                                       class="st-input"
                                                       autocomplete="new-password"
                                                       @bind-Value="FormModel.NewPassword" />
                                            <ValidationMessage For="() => FormModel.NewPassword" class="validation-message" />
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <div class="st-field mb-0">
                                            <label for="confirm-new-password" class="st-label">Confirm New Password</label>
                                            <InputText id="confirm-new-password"
                                                       type="password"
                                                       class="st-input"
                                                       autocomplete="new-password"
                                                       @bind-Value="FormModel.ConfirmNewPassword" />
                                            <ValidationMessage For="() => FormModel.ConfirmNewPassword" class="validation-message" />
                                        </div>
                                    </div>
                                </div>
                            </fieldset>

                            <div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-2 mt-4 pt-4 border-top">
                                <button type="submit" class="st-btn st-btn--primary" disabled="@isSaving">
                                    @(isSaving ? "Resetting Password..." : "Reset Password")
                                </button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    // Gets the selected user ID from the route.
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    // Stores the posted form values for the admin password-reset page.
    [SupplyParameterFromForm(FormName = "ResetUserPassword")]
    private AdminResetPasswordViewModel? model { get; set; }

    // Always provides a safe non-null model instance for rendering and form binding.
    private AdminResetPasswordViewModel FormModel => model ??= new();

    // Stores a service or unexpected error shown above the form.
    private string? errorMessage;

    // Stores the success message shown after the password is reset.
    private string? successMessage;

    // Stores the not-found message if the requested user does not exist.
    private string? notFoundMessage;

    // Shows one short validation prompt after an invalid submit.
    private bool showValidationMessage;

    // Controls the loading state while the selected user is being fetched.
    private bool isLoading = true;

    // Prevents duplicate submits and locks the form while saving.
    private bool isSaving;

    // Stores the selected user's display name for the page title and summary message.
    private string targetDisplayName = string.Empty;

    // Stores the selected user's email for the summary message.
    private string? targetEmail;

    // Reloads the selected user whenever the route parameter changes.
    protected override async Task OnParametersSetAsync()
    {
        await LoadUserAsync();
    }

    // Loads the selected user details used by this password-reset page.
    private async Task LoadUserAsync()
    {
        errorMessage = null;
        successMessage = null;
        notFoundMessage = null;
        showValidationMessage = false;
        isLoading = true;

        // Resets the form but keeps the target user ID in the model.
        model = new AdminResetPasswordViewModel
        {
            UserId = UserId
        };

        try
        {
            // Loads the selected user from the admin service.
            var loadedUser = await UserAdminService.GetUserByIdAsync(UserId);

            // Stops the workflow cleanly if the requested user does not exist.
            if (loadedUser is null)
            {
                notFoundMessage = "The requested user could not be found.";
                targetDisplayName = string.Empty;
                targetEmail = null;
                return;
            }

            // Builds a readable display name from the loaded user details.
            var fullName = $"{loadedUser.FirstName} {loadedUser.LastName}".Trim();

            // Stores the selected user details for display.
            targetDisplayName = string.IsNullOrWhiteSpace(fullName) ? "Selected User" : fullName;
            targetEmail = loadedUser.Email;
            FormModel.UserId = loadedUser.UserId;
        }
        catch
        {
            // Shows a fallback message if the selected user cannot be loaded.
            errorMessage = "Something went wrong while loading the user.";
            targetDisplayName = string.Empty;
            targetEmail = null;
        }
        finally
        {
            // Ends the loading state whether the request succeeded or failed.
            isLoading = false;
        }
    }

    // Runs only when the form passes view-model validation.
    private async Task HandleValidSubmit()
    {
        // Stops accidental double-submit if the save is already running.
        if (isSaving)
        {
            return;
        }

        // Clears old messages before starting a fresh reset attempt.
        errorMessage = null;
        successMessage = null;
        showValidationMessage = false;
        isSaving = true;

        try
        {
            // Gets the current authenticated admin user from the Blazor authentication state.
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

            // Reads the signed-in admin user ID from the claims collection.
            var currentAdminUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            // Blocks the action if the current admin user cannot be identified safely.
            if (string.IsNullOrWhiteSpace(currentAdminUserId))
            {
                errorMessage = "The current signed-in user could not be identified.";
                return;
            }

            // Makes sure the submitted model still targets the selected route user.
            FormModel.UserId = UserId;

            // Sends the password-reset request into the admin service layer.
            await UserAdminService.ResetUserPasswordAsync(FormModel, currentAdminUserId);

            // Shows success and clears only the password fields after a completed reset.
            successMessage = "Password reset successfully.";
            model = new AdminResetPasswordViewModel
            {
                UserId = UserId
            };
        }
        catch (InvalidOperationException ex)
        {
            // Shows expected business-rule or Identity errors from the service layer.
            errorMessage = ex.Message;
        }
        catch
        {
            // Shows a fallback message for unexpected failures.
            errorMessage = "Something went wrong while resetting the password.";
        }
        finally
        {
            // Re-enables the form whether the operation succeeded or failed.
            isSaving = false;
        }
    }

    // Runs when submit happens but validation fails.
    private void HandleInvalidSubmit(EditContext editContext)
    {
        // Keeps the top message short and leaves detailed errors next to each field.
        errorMessage = null;
        successMessage = null;
        showValidationMessage = true;
    }
}

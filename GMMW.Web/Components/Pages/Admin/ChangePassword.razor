@page "/account/change-password"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using GMMW.Web.Models.ViewModels
@using GMMW.Web.Services.Interfaces
@attribute [Authorize]
@inject IPasswordService PasswordService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Change Password</PageTitle>

<div class="row">
    <div class="col-12 col-xl-8 col-xxl-7">
        <div class="st-stack-lg">
            <div class="st-page-header">
                <div class="st-page-header__copy">
                    <h1 class="st-page-title">Change Password</h1>
                    <p class="st-page-subtitle">
                        Update the password for your currently signed-in account.
                    </p>
                </div>
            </div>

            <EditForm Model="FormModel"
                      OnValidSubmit="HandleValidSubmit"
                      OnInvalidSubmit="HandleInvalidSubmit"
                      FormName="ChangePassword">
                <DataAnnotationsValidator />

                <div class="st-card">
                    <div class="st-card__header">
                        <div>
                            <h2 class="st-card-title">Password Details</h2>
                            <p class="st-card-subtitle">
                                Enter your current password, then choose and confirm a new one.
                            </p>
                        </div>
                    </div>

                    <div class="st-card__body">
                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="st-alert st-alert--danger mb-3" role="alert" aria-live="polite">
                                @errorMessage
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="st-alert st-alert--success mb-3" role="status" aria-live="polite">
                                @successMessage
                            </div>
                        }

                        @if (showValidationMessage &&
                                                     string.IsNullOrWhiteSpace(errorMessage) &&
                                                     string.IsNullOrWhiteSpace(successMessage))
                        {
                            <div class="st-alert st-alert--warning mb-3" role="alert">
                                Please correct the highlighted fields and try again.
                            </div>
                        }

                        <fieldset disabled="@isSaving" aria-busy="@isSaving">
                            <div class="row g-4">
                                <div class="col-12">
                                    <div class="st-field mb-0">
                                        <label for="current-password" class="st-label">Current Password</label>
                                        <InputText id="current-password"
                                                   type="password"
                                                   class="st-input"
                                                   autocomplete="current-password"
                                                   @bind-Value="FormModel.CurrentPassword" />
                                        <ValidationMessage For="() => FormModel.CurrentPassword" class="validation-message" />
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="st-field mb-0">
                                        <label for="new-password" class="st-label">New Password</label>
                                        <InputText id="new-password"
                                                   type="password"
                                                   class="st-input"
                                                   autocomplete="new-password"
                                                   @bind-Value="FormModel.NewPassword" />
                                        <ValidationMessage For="() => FormModel.NewPassword" class="validation-message" />
                                    </div>
                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="st-field mb-0">
                                        <label for="confirm-new-password" class="st-label">Confirm New Password</label>
                                        <InputText id="confirm-new-password"
                                                   type="password"
                                                   class="st-input"
                                                   autocomplete="new-password"
                                                   @bind-Value="FormModel.ConfirmNewPassword" />
                                        <ValidationMessage For="() => FormModel.ConfirmNewPassword" class="validation-message" />
                                    </div>
                                </div>
                            </div>
                        </fieldset>

                        <div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-2 mt-4 pt-4 border-top">
                            <button type="submit" class="st-btn st-btn--primary" disabled="@isSaving">
                                @(isSaving ? "Changing Password..." : "Change Password")
                            </button>
                        </div>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    // Stores the posted form values for the change-password page.
    [SupplyParameterFromForm(FormName = "ChangePassword")]
    private ChangePasswordViewModel? model { get; set; }

    // Always provides a safe non-null model instance for rendering and form binding.
    private ChangePasswordViewModel FormModel => model ??= new();

    // Stores a service or unexpected error shown above the form.
    private string? errorMessage;

    // Stores the success message shown after the password is changed.
    private string? successMessage;

    // Shows one short validation prompt after an invalid submit.
    private bool showValidationMessage;

    // Prevents duplicate submits and locks the form while saving.
    private bool isSaving;

    // Runs only when the form passes view-model validation.
    private async Task HandleValidSubmit()
    {
        // Stops accidental double-submit if the save is already running.
        if (isSaving)
        {
            return;
        }

        // Clears old messages before starting a fresh change attempt.
        errorMessage = null;
        successMessage = null;
        showValidationMessage = false;
        isSaving = true;

        try
        {
            // Gets the current authenticated user from the Blazor authentication state.
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

            // Reads the signed-in user ID from the claims collection.
            var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            // Blocks the action if the current user cannot be identified safely.
            if (string.IsNullOrWhiteSpace(currentUserId))
            {
                errorMessage = "The current signed-in user could not be identified.";
                return;
            }

            // Sends the change-password request into the service layer.
            await PasswordService.ChangePasswordAsync(currentUserId, FormModel);

            // Shows success and clears the form after a completed password change.
            successMessage = "Password changed successfully.";
            model = new ChangePasswordViewModel();
        }
        catch (InvalidOperationException ex)
        {
            // Shows expected service-layer validation or business-rule errors.
            errorMessage = ex.Message;
        }
        catch
        {
            // Shows a fallback message for unexpected failures.
            errorMessage = "Something went wrong while changing the password.";
        }
        finally
        {
            // Re-enables the form whether the operation succeeded or failed.
            isSaving = false;
        }
    }

    // Runs when submit happens but validation fails.
    private void HandleInvalidSubmit(EditContext editContext)
    {
        // Keeps the top message short and leaves detailed errors next to each field.
        errorMessage = null;
        successMessage = null;
        showValidationMessage = true;
    }
}
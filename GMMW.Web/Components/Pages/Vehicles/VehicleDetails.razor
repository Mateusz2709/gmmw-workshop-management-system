@page "/vehicles/details/{vehicleId:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using GMMW.Web.Services.Interfaces
@using Microsoft.AspNetCore.Components
@inject IVehicleService VehicleService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@using GMMW.Web.Models.Domain
@inject IJSRuntime JS
@inject IRepairService RepairService

<PageTitle>@(vehicle is null ? "Vehicle Details" : vehicle.RegistrationNumber)</PageTitle>

<div class="st-stack-lg">
    <div class="st-page-header">
        <div class="st-page-header__copy">
            <h1 class="st-page-title">
                @(vehicle is null ? "Vehicle Details" : vehicle.RegistrationNumber)
            </h1>
            <p class="st-page-subtitle">
                Review the selected vehicle, its linked owner, and the repair history recorded for this record.
            </p>
        </div>

        @if (vehicle is not null)
        {
            <div class="st-page-actions">
                <a href="/vehicles/search" class="st-btn st-btn--secondary">Search Vehicles</a>
                <a href="@($"/vehicles/edit/{vehicle.VehicleId}")" class="st-btn st-btn--secondary">Edit Vehicle</a>
                <button type="button" class="st-btn st-btn--danger" @onclick="DeleteVehicleAsync">Delete</button>
            </div>
        }
    </div>

    @if (isLoading)
    {
        <div class="st-alert st-alert--info" role="status">
            Loading vehicle details...
        </div>
    }
    else if (vehicle is null)
    {
        <div class="st-alert st-alert--danger" role="alert">
            @errorMessage
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="st-alert st-alert--danger" role="alert">
                @errorMessage
            </div>
        }

        <div class="row g-4">
            <div class="col-12 col-xl-6">
                <div class="st-card st-detail-card h-100">
                    <div class="st-card__body">
                        <div class="st-detail-card__heading">
                            <div class="st-detail-card__icon">V</div>
                            <div>
                                <h2 class="st-section-title mb-1">Vehicle Information</h2>
                                <p class="st-card-subtitle mb-0">
                                    Core details stored for this vehicle record.
                                </p>
                            </div>
                        </div>

                        <div class="st-detail-list">
                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Registration Number</div>
                                <div class="st-detail-list__value">@vehicle.RegistrationNumber</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Vehicle Type</div>
                                <div class="st-detail-list__value">@vehicle.VehicleType</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Make</div>
                                <div class="st-detail-list__value">@vehicle.Make</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Model</div>
                                <div class="st-detail-list__value">@vehicle.Model</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Year</div>
                                <div class="st-detail-list__value">@(vehicle.Year?.ToString() ?? "—")</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Vehicle ID</div>
                                <div class="st-detail-list__value">@vehicle.VehicleId</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="st-card st-detail-card h-100">
                    <div class="st-card__body">
                        <div class="st-detail-card__heading">
                            <div class="st-detail-card__icon">O</div>
                            <div>
                                <h2 class="st-section-title mb-1">Owner Information</h2>
                                <p class="st-card-subtitle mb-0">
                                    Contact details for the motorist linked to this vehicle.
                                </p>
                            </div>
                        </div>

                        <div class="st-detail-list">
                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Owner Name</div>
                                <div class="st-detail-list__value">@vehicle.Motorist.FirstName @vehicle.Motorist.LastName</div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Email</div>
                                <div class="st-detail-list__value">
                                    @(string.IsNullOrWhiteSpace(vehicle.Motorist.Email) ? "—" : vehicle.Motorist.Email)
                                </div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Phone Number</div>
                                <div class="st-detail-list__value">
                                    @(string.IsNullOrWhiteSpace(vehicle.Motorist.PhoneNumber) ? "—" : vehicle.Motorist.PhoneNumber)
                                </div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Address</div>
                                <div class="st-detail-list__value">
                                    @(string.IsNullOrWhiteSpace(vehicle.Motorist.Address) ? "—" : vehicle.Motorist.Address)
                                </div>
                            </div>

                            <div class="st-detail-list__row">
                                <div class="st-detail-list__label">Motorist ID</div>
                                <div class="st-detail-list__value">@vehicle.MotoristId</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="st-card">
            <div class="st-card__header">
                <div>
                    <h2 class="st-card-title">Latest Linked Repair</h2>
                    <p class="st-card-subtitle">
                        @(linkedRepairs.Any()
                            ? "Showing the most recent repair for this vehicle. Open View All Repairs to see the full repair history."
                            : "No repair records have been linked to this vehicle yet.")
                    </p>
                </div>
            </div>

            <div class="st-card__body">
                @if (linkedRepairs.Any())
                {
                    <div class="st-table-shell">
                        <div class="table-responsive">
                            <table class="st-table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Repair ID</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Summary</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var repair in linkedRepairs)
                                    {
                                        <tr>
                                            <td>@repair.RepairId</td>
                                            <td>@repair.RepairDate.ToShortDateString()</td>
                                            <td>@repair.RepairStatus</td>
                                            <td>@repair.FaultDescription</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="st-empty">
                        <span class="st-empty__title">No linked repairs</span>
                        No repairs have been recorded for this vehicle yet.
                    </div>
                }

                <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4">
                    <a href="@($"/vehicles/details/{VehicleId}/repairs")" class="st-btn st-btn--secondary">
                        View All Repairs
                    </a>
                    <a href="@($"/vehicles/details/{VehicleId}/repairs/create")" class="st-btn st-btn--primary">
                        Book Repair
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Receives the vehicle ID from the route, for example /vehicles/details/12.
    [Parameter]
    public int VehicleId { get; set; }

    // Stores the loaded vehicle record for display on the page.
    private Vehicle? vehicle;

    // Stores a compact preview list of repairs linked to this vehicle.
    private List<Repair> linkedRepairs = new();

    // Controls how many repairs appear in the compact preview table.
    private const int RepairPreviewCount = 1;

    // Stores a page-level error message if the vehicle cannot be loaded.
    private string? errorMessage;

    // Tracks whether the page is still loading data from the service.
    private bool isLoading = true;


    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        errorMessage = null;

        try
        {
            vehicle = await VehicleService.GetVehicleByIdAsync(VehicleId);

            if (vehicle is null)
            {
                errorMessage = "The requested vehicle could not be found.";
            }
            else
            {
                linkedRepairs = (await RepairService.GetRepairsByVehicleIdAsync(VehicleId))
                .Take(RepairPreviewCount)
                .ToList();
            }
        }
        catch
        {
            errorMessage = "Vehicle details could not be loaded.";
        }
        finally
        {
            isLoading = false;
        }

    }

    // Runs when the user tries to delete a vehicle.
    private async Task DeleteVehicleAsync()
    {
        if (vehicle is null)
        {
            return;
        }
        // Clears any old page-level error before starting a new delete attempt.
        errorMessage = null;
        // Shows a browser confirmation dialog before continuing with the delete action.
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this vehicle?");

        // Stops the delete immediately if the user cancels the confirmation dialog.
        if (!confirmed)
        {
            return;
        }

        try
        {
            // Calls the service to delete the selected vehicle using its ID.
            await VehicleService.DeleteVehicleAsync(vehicle.VehicleId);
            // Redirects the user.
            NavigationManager.NavigateTo($"/motorists/details/{vehicle.MotoristId}");
        }
        catch (InvalidOperationException ex)
        {
            // Shows a friendly business-rule error, for example when the vehicle has linked repairs.
            errorMessage = ex.Message;
        }
    }
}

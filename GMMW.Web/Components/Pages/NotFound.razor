@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found</PageTitle>

<div class="st-stack-lg">
    <div class="st-page-header">
        <div class="st-page-header__copy">
            <h1 class="st-page-title">Page Not Found</h1>
            <p class="st-page-subtitle">
                The page you were trying to open does not exist or is no longer available.
            </p>
        </div>
    </div>

    <div class="st-card">
        <div class="st-card__header">
            <div>
                <h2 class="st-card-title">Nothing found</h2>
                <p class="st-card-subtitle">
                    Check the address or return to a page that is available in the system.
                </p>
            </div>
        </div>

        <div class="st-card__body">
            <div class="st-alert st-alert--warning mb-4" role="alert">
                Sorry, the content you are looking for could not be found.
            </div>

            <div class="d-flex flex-column flex-sm-row justify-content-end gap-2">
                <a href="/dashboard" class="st-btn st-btn--secondary">Back to Dashboard</a>
                <a href="/public/todayclasses" class="st-btn st-btn--primary">Today’s Classes</a>
            </div>
        </div>
    </div>
</div>
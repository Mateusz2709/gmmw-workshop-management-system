@page "/reports/volunteer-classes"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using GMMW.Web.Components.Shared
@using GMMW.Web.Models.ViewModels
@using GMMW.Web.Services.Interfaces
@inject IReportService ReportService
@inject IClassService ClassService

<PageTitle>Volunteer Class Report</PageTitle>

<div class="st-stack-lg">
    <div class="st-page-header">
        <div class="st-page-header__copy">
            <h1 class="st-page-title">Volunteer Class Report</h1>
            <p class="st-page-subtitle">
                Review the classes delivered by a selected volunteer in a chosen month.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="st-alert st-alert--danger" role="alert" aria-live="polite">
            @errorMessage
        </div>
    }

    <div class="st-card st-card--allow-overflow">
        <div class="st-card__header">
            <div>
                <h2 class="st-card-title">Report Filters</h2>
                <p class="st-card-subtitle">
                    Select a month and year, then choose a volunteer to load the classes they delivered in that reporting period.
                </p>
            </div>
        </div>

        <div class="st-card__body">
            <div class="row g-4 align-items-end">
                <div class="col-12 col-md-4 col-xl-3">
                    <StSelectPicker Label="Month"
                                    Value="@SelectedMonthValue"
                                    ValueChanged="OnSelectedMonthChangedAsync"
                                    Options="MonthOptions" />
                </div>

                <div class="col-12 col-md-4 col-xl-3">
                    <StSelectPicker Label="Year"
                                    Value="@SelectedYearValue"
                                    ValueChanged="OnSelectedYearChangedAsync"
                                    Options="YearOptions" />
                </div>

                <div class="col-12 col-xl-6">
                    <div class="st-field mb-0">
                        <label for="volunteer-filter-search" class="st-label">Volunteer</label>

                        <div class="row g-2 align-items-end">
                            <div class="col-12 col-sm">
                                @if (selectedVolunteerFilter is null)
                                {
                                    <div class="st-autocomplete">
                                        <input id="volunteer-filter-search"
                                               class="st-input"
                                               type="text"
                                               placeholder="Type at least 2 characters"
                                               value="@volunteerFilterSearchTerm"
                                               @oninput="HandleVolunteerFilterInput"
                                               @onfocus="HandleVolunteerFilterFocus"
                                               @onblur="HandleVolunteerFilterBlur" />

                                        @if (isVolunteerFilterDropdownOpen && volunteerFilterSearchResults.Any())
                                        {
                                            <div class="st-autocomplete__menu">
                                                @foreach (var volunteer in volunteerFilterSearchResults)
                                                {
                                                    <button type="button"
                                                            class="st-autocomplete__item"
                                                            @onclick="() => SelectVolunteerFilter(volunteer)">
                                                        <span class="st-autocomplete__primary">@volunteer.DisplayName</span>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="st-selected-summary">
                                        <div class="st-selected-summary__title">@selectedVolunteerFilter.DisplayName</div>
                                        <div class="st-selected-summary__meta">Volunteer filter applied</div>
                                    </div>
                                }
                            </div>

                            <div class="col-12 col-sm-auto">
                                <button type="button"
                                        class="st-btn st-btn--secondary w-100"
                                        @onclick="ClearVolunteerFilter"
                                        disabled="@(!CanClearVolunteerFilter || isLoading)">
                                    @(selectedVolunteerFilter is null ? "Clear" : "Change")
                                </button>
                            </div>
                        </div>

                        <div class="st-muted small mt-2">
                            Start typing at least 2 characters, then select a volunteer from the list.
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 pt-2">
                        <button type="button"
                                class="st-btn st-btn--primary"
                                @onclick="ApplyFiltersAsync"
                                disabled="@isLoading">
                            Apply Filters
                        </button>

                        <button type="button"
                                class="st-btn st-btn--secondary"
                                @onclick="ClearFiltersAsync"
                                disabled="@(!CanResetFilters || isLoading)">
                            Reset Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="st-card">
        <div class="st-card__header">
            <div>
                <h2 class="st-card-title">Volunteer Class Results</h2>
                <p class="st-card-subtitle">@ResultsSubtitle</p>
            </div>
        </div>

        <div class="st-card__body">
            @if (isLoading)
            {
                <div class="st-alert st-alert--info" role="status">
                    Loading volunteer class results...
                </div>
            }
            else if (!HasLoadedVolunteerReport)
            {
                <div class="st-empty">
                    <span class="st-empty__title">Select a volunteer to load the report</span>
                    Choose a volunteer and apply the filters to review the classes they delivered.
                </div>
            }
            else if (reportItems.Count == 0)
            {
                <div class="st-empty">
                    <span class="st-empty__title">No classes found for the selected volunteer</span>
                    Try a different month or choose another volunteer.
                </div>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="st-card h-100">
                            <div class="st-card__body">
                                <div class="d-flex flex-column gap-2">
                                    <span class="st-label mb-0">Reporting Period</span>
                                    <div class="fs-4 fw-semibold">@ReportMonthName @reportYear</div>
                                    <p class="st-page-subtitle mb-0">
                                        Month and year currently loaded for this report.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="st-card h-100">
                            <div class="st-card__body">
                                <div class="d-flex flex-column gap-2">
                                    <span class="st-label mb-0">Volunteer</span>
                                    <div class="fs-4 fw-semibold">@LoadedVolunteerName</div>
                                    <p class="st-page-subtitle mb-0">
                                        Volunteer currently loaded for this report.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-12 col-xl-4">
                        <div class="st-card h-100">
                            <div class="st-card__body">
                                <div class="d-flex flex-column gap-2">
                                    <span class="st-label mb-0">Classes Delivered</span>
                                    <div class="fs-2 fw-bold">@reportItems.Count</div>
                                    <p class="st-page-subtitle mb-0">
                                        Total classes delivered in the loaded reporting period.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="st-card mt-4">
                    <div class="st-card__body">
                        <div class="row g-3 align-items-center">
                            <div class="col-12 col-lg-8">
                                <h3 class="st-card-title mb-2">Summary</h3>
                                <p class="mb-0 text-muted">
                                    @SummaryText
                                </p>
                            </div>
                            <div class="col-12 col-lg-4">
                                <div class="d-flex justify-content-lg-end">
                                    <span class="st-inline-status st-inline-status--info">
                                        Reporting period loaded
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="st-card mt-4">
                    <div class="st-card__header">
                        <div>
                            <h3 class="st-card-title">Delivered Classes</h3>
                            <p class="st-card-subtitle">
                                Class title, class date, and time range for the loaded volunteer and reporting period.
                            </p>
                        </div>
                    </div>

                    <div class="st-card__body p-0">
                        <div class="st-table-shell">
                            <div class="table-responsive">
                                <table class="st-table align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Class</th>
                                            <th>Class Date</th>
                                            <th>Time</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in reportItems)
                                        {
                                            <tr>
                                                <td>@item.ClassTitle</td>
                                                <td>@item.ClassDate.ToString("dd/MM/yyyy")</td>
                                                <td>@FormatTimeRange(item.StartTime, item.EndTime)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // Stores the final volunteer class report rows returned by the reporting service.
    private List<VolunteerClassReportItemViewModel> reportItems = new();

    // Stores the available selectable volunteers for the filter picker.
    private List<ApplicationUserOptionViewModel> volunteerOptions = new();

    // Stores the current filtered dropdown results for the volunteer search.
    private List<ApplicationUserOptionViewModel> volunteerFilterSearchResults = new();

    // Stores the currently selected volunteer in the filter UI.
    private ApplicationUserOptionViewModel? selectedVolunteerFilter;

    // Stores the text entered into the volunteer filter search input.
    private string volunteerFilterSearchTerm = string.Empty;

    // Stores the currently selected volunteer ID in the filter UI.
    private string selectedVolunteerUserId = string.Empty;

    // Stores a page-level error message if loading fails.
    private string? errorMessage;

    // Tracks whether the page is currently loading report data.
    private bool isLoading = true;

    // Controls whether the custom volunteer autocomplete dropdown is visible.
    private bool isVolunteerFilterDropdownOpen;

    // Stores the selected year in the filter UI.
    private int selectedYear = DateTime.Today.Year;

    // Stores the selected month in the filter UI.
    private int selectedMonth = DateTime.Today.Month;

    // Stores the year for the report that has actually been loaded.
    private int reportYear = DateTime.Today.Year;

    // Stores the month for the report that has actually been loaded.
    private int reportMonth = DateTime.Today.Month;

    // Stores the volunteer ID for the report that has actually been loaded.
    private string reportVolunteerUserId = string.Empty;

    // Stores the volunteer display name for the report that has actually been loaded.
    private string reportVolunteerDisplayName = string.Empty;

    // Controls whether the volunteer clear/change button should be enabled.
    private bool CanClearVolunteerFilter =>
        !string.IsNullOrWhiteSpace(volunteerFilterSearchTerm) || selectedVolunteerFilter is not null;

    // Controls whether Reset Filters should be enabled.
    private bool CanResetFilters =>
        selectedYear != DateTime.Today.Year
        || selectedMonth != DateTime.Today.Month
        || !string.IsNullOrWhiteSpace(selectedVolunteerUserId)
        || HasLoadedVolunteerReport
        || !string.IsNullOrWhiteSpace(volunteerFilterSearchTerm);

    // Returns the year options shown in the year dropdown.
    private IEnumerable<int> AvailableYears => Enumerable.Range(DateTime.Today.Year - 2, 5);

    // Returns the month options shown in the custom month dropdown.
    private IReadOnlyDictionary<string, string> MonthOptions =>
        Enumerable.Range(1, 12)
            .ToDictionary(
                month => month.ToString(CultureInfo.InvariantCulture),
                month => CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month));

    // Returns the year options shown in the custom year dropdown.
    private IReadOnlyDictionary<string, string> YearOptions =>
        AvailableYears.ToDictionary(
            year => year.ToString(CultureInfo.InvariantCulture),
            year => year.ToString(CultureInfo.InvariantCulture));

    // Returns the selected month as a string for the custom dropdown.
    private string SelectedMonthValue => selectedMonth.ToString(CultureInfo.InvariantCulture);

    // Returns the selected year as a string for the custom dropdown.
    private string SelectedYearValue => selectedYear.ToString(CultureInfo.InvariantCulture);

    // Returns the month name for the loaded report period.
    private string ReportMonthName => CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(reportMonth);

    // Returns true when a volunteer report has actually been loaded.
    private bool HasLoadedVolunteerReport => !string.IsNullOrWhiteSpace(reportVolunteerUserId);

    // Returns the loaded volunteer name or a safe fallback.
    private string LoadedVolunteerName =>
        string.IsNullOrWhiteSpace(reportVolunteerDisplayName)
            ? "—"
            : reportVolunteerDisplayName;

    // Returns the results subtitle shown in the results card header.
    private string ResultsSubtitle =>
        !HasLoadedVolunteerReport
            ? "Select a volunteer and apply the filters to load the report."
            : reportItems.Count == 0
                ? $"No classes were found for {LoadedVolunteerName} in {ReportMonthName} {reportYear}."
                : $"Showing {reportItems.Count} class record{(reportItems.Count == 1 ? "" : "s")} delivered by {LoadedVolunteerName} in {ReportMonthName} {reportYear}.";

    // Returns the summary sentence shown below the cards.
    private string SummaryText =>
        $"In {ReportMonthName} {reportYear}, {LoadedVolunteerName} delivered {reportItems.Count} {(reportItems.Count == 1 ? "class" : "classes")}.";

    // Runs automatically when the page first loads.
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Loads the available class deliverers used by the volunteer filter picker.
            volunteerOptions = await ClassService.GetAvailableClassDeliverersAsync();

            // Keeps the page in a ready state without forcing an initial report load.
            isLoading = false;
        }
        catch
        {
            // Stores a friendly error message if the page cannot be loaded.
            errorMessage = "The volunteer class report page could not be loaded. Please refresh the page and try again.";
            reportItems = new List<VolunteerClassReportItemViewModel>();
            isLoading = false;
        }
    }

    // Stores the selected month from the custom dropdown safely.
    private Task OnSelectedMonthChangedAsync(string value)
    {
        if (int.TryParse(value, NumberStyles.None, CultureInfo.InvariantCulture, out var parsedMonth)
            && parsedMonth >= 1
            && parsedMonth <= 12)
        {
            selectedMonth = parsedMonth;
            errorMessage = null;
        }

        return Task.CompletedTask;
    }

    // Stores the selected year from the custom dropdown safely.
    private Task OnSelectedYearChangedAsync(string value)
    {
        if (int.TryParse(value, NumberStyles.None, CultureInfo.InvariantCulture, out var parsedYear))
        {
            selectedYear = parsedYear;
            errorMessage = null;
        }

        return Task.CompletedTask;
    }

    // Loads the volunteer class report using the selected month, year, and volunteer.
    private async Task LoadReportAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Requests the report rows for the selected reporting period and volunteer.
            var loadedItems = await ReportService.GetVolunteerClassReportAsync(
                selectedMonth,
                selectedYear,
                selectedVolunteerUserId);

            // Stores the loaded results and the exact filter state they belong to.
            reportItems = loadedItems;
            reportMonth = selectedMonth;
            reportYear = selectedYear;
            reportVolunteerUserId = selectedVolunteerUserId;
            reportVolunteerDisplayName = selectedVolunteerFilter?.DisplayName ?? string.Empty;
        }
        catch
        {
            errorMessage = "The volunteer class report could not be loaded. Please try again.";
            ClearLoadedReportState();
        }
        finally
        {
            isLoading = false;
        }
    }

    // Applies the selected filters and reloads the report results.
    private async Task ApplyFiltersAsync()
    {
        // Stops the load if typed text was not chosen from the list.
        if (!string.IsNullOrWhiteSpace(volunteerFilterSearchTerm) && selectedVolunteerFilter is null)
        {
            errorMessage = "Please select a valid volunteer from the list, or clear the volunteer filter.";
            return;
        }

        // Stops the load if no volunteer was selected at all.
        if (selectedVolunteerFilter is null || string.IsNullOrWhiteSpace(selectedVolunteerUserId))
        {
            errorMessage = "Please select a volunteer before loading the report.";
            return;
        }

        errorMessage = null;
        await LoadReportAsync();
    }

    // Resets all filters back to their default values and clears the loaded report.
    private Task ClearFiltersAsync()
    {
        selectedYear = DateTime.Today.Year;
        selectedMonth = DateTime.Today.Month;
        ClearVolunteerFilter();
        ClearLoadedReportState();
        errorMessage = null;
        isLoading = false;

        return Task.CompletedTask;
    }

    // Clears the currently loaded report state.
    private void ClearLoadedReportState()
    {
        reportItems = new List<VolunteerClassReportItemViewModel>();
        reportVolunteerUserId = string.Empty;
        reportVolunteerDisplayName = string.Empty;
        reportMonth = selectedMonth;
        reportYear = selectedYear;
    }

    // Runs when the user types in the volunteer filter search box and updates the autocomplete results.
    private Task HandleVolunteerFilterInput(ChangeEventArgs e)
    {
        volunteerFilterSearchTerm = e.Value?.ToString() ?? string.Empty;
        errorMessage = null;
        selectedVolunteerFilter = null;
        selectedVolunteerUserId = string.Empty;

        if (string.IsNullOrWhiteSpace(volunteerFilterSearchTerm) || volunteerFilterSearchTerm.Trim().Length < 2)
        {
            volunteerFilterSearchResults.Clear();
            isVolunteerFilterDropdownOpen = false;
            return Task.CompletedTask;
        }

        volunteerFilterSearchResults = volunteerOptions
            .Where(option => option.DisplayName.Contains(volunteerFilterSearchTerm.Trim(), StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList();

        isVolunteerFilterDropdownOpen = volunteerFilterSearchResults.Any();
        return Task.CompletedTask;
    }

    // Applies the chosen volunteer to the filter state.
    private void SelectVolunteerFilter(ApplicationUserOptionViewModel volunteer)
    {
        selectedVolunteerFilter = volunteer;
        selectedVolunteerUserId = volunteer.UserId;
        volunteerFilterSearchTerm = volunteer.DisplayName;
        volunteerFilterSearchResults.Clear();
        isVolunteerFilterDropdownOpen = false;
        errorMessage = null;
    }

    // Clears the volunteer filter search state and removes any current volunteer filter.
    private void ClearVolunteerFilter()
    {
        volunteerFilterSearchTerm = string.Empty;
        volunteerFilterSearchResults.Clear();
        selectedVolunteerFilter = null;
        selectedVolunteerUserId = string.Empty;
        isVolunteerFilterDropdownOpen = false;
        errorMessage = null;
    }

    // Reopens the volunteer autocomplete dropdown when the input gains focus and results still exist.
    private void HandleVolunteerFilterFocus()
    {
        if (volunteerFilterSearchResults.Any())
        {
            isVolunteerFilterDropdownOpen = true;
        }
    }

    // Closes the volunteer autocomplete dropdown shortly after the input loses focus.
    private async Task HandleVolunteerFilterBlur()
    {
        await Task.Delay(150);
        isVolunteerFilterDropdownOpen = false;
    }

    // Formats the displayed class time range using a readable 12-hour format.
    private static string FormatTimeRange(TimeSpan startTime, TimeSpan endTime)
    {
        var formattedStartTime = DateTime.Today.Add(startTime).ToString("hh:mm tt");
        var formattedEndTime = DateTime.Today.Add(endTime).ToString("hh:mm tt");

        return $"{formattedStartTime} - {formattedEndTime}";
    }
}